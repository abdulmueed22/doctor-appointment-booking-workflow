    {
      "parameters": {
        "jsCode": "const toolCall = $json.body?.message?.toolCallList?.[0];\n\nreturn [\n  {\n    json: {\n      preferred_date: toolCall?.function?.arguments?.preferred_date || null,\n      preferred_time: toolCall?.function?.arguments?.preferred_time || null,\n      tool_name: toolCall?.function?.name || null,\n      tool_call_id: toolCall?.id || null,\n    }\n  }\n];"
      },
