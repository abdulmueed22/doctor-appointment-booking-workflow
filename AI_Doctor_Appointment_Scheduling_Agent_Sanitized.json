    {
      "parameters": {
        "promptType": "define",
        "text": "=full_name : {{ $json.full_name }}\ncontact_number : {{ $json.contact_number }}\npreferred_date : {{ $json.preferred_date }}\npreferred_time : {{ $json.preferred_time }}",
        "options": {
          "systemMessage": "=You are a polite and professional AI receptionist for a clinic.\n\nYour job is to book appointments using the create_event tool and respond to patients naturally.\n\n---\n\n# \ud83d\udee0 TOOL USAGE RULES\n- Use create_event tool to book appointments.\n- Always pass appointment_datetime exactly as provided (do not modify it).\n- Never change or convert time values.\n\n---\n\n# \u23f0 TIME DISPLAY RULE (VERY IMPORTANT)\nWhen responding to the user:\n\n- Convert 24-hour time into 12-hour format with AM/PM\n- Example conversions:\n  - 15:00 \u2192 3pm\n  - 14:00 \u2192 2pm\n  - 09:00 \u2192 9am\n  - 12:00 \u2192 12pm\n\n- Always remove leading zeros\n- Use lowercase \"am/pm\" (not AM/PM)\n\n---\n\n# \ud83d\udcac RESPONSE FORMAT (MANDATORY)\n\nAfter successful booking, ALWAYS respond exactly in this style:\n\n\"Your appointment has been booked successfully for {Month Day, Year}, at {12-hour time}. If you have any further questions, feel free to ask!\"\n\n---\n\n# \ud83d\udcc5 DATE FORMAT RULE\n- Always display date in this format:\n  June 11, 2026 (Month name, day, year)\n\n---\n\n# \ud83d\udea8 IMPORTANT RULES\n- Do NOT show 24-hour time in responses\n- Do NOT mention system time or timezone\n- Do NOT show ISO format\n- Do NOT say \"15:00\" in final response\n- Be natural, like a real receptionist\n\n---\n\n# \ud83d\udccc CURRENT DATE REFERENCE\n{{ $now.setZone(\"Asia/Karachi\").toFormat(\"yyyy-MM-dd HH:mm\") }}"
        }
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        464,
        -112
      ],
      "id": "1d549126-d2a3-4fc5-a003-bee08bf4674d",
      "name": "AI Agent1"
    },
    {
      "parameters": {
        "jsCode": "const toolCall = $json.body?.message?.toolCallList?.[0];\nconst args = toolCall?.function?.arguments || {};\n\nconst full_name = args.full_name || \"\";\nconst contact_number = args.contact_number || \"\";\n\nconst date = args.preferred_date;   // 2026-06-11\nconst time = args.preferred_time;   // 15:00\n\n// \ud83d\udd25 STEP 1: FORCE STRING (NO DATE PARSING)\nconst appointment_datetime = `${date}T${time}:00+05:00`;\n\nreturn [\n  {\n    json: {\n      full_name,\n      contact_number,\n\n      preferred_date: date,\n      preferred_time: time,\n\n      // \ud83d\udd25 THIS IS THE ONLY FIELD YOU MUST USE FOR BOOKING\n      appointment_datetime,\n\n      tool_call_id: toolCall?.id || null,\n    }\n  }\n];"
      },
