        "jsCode": "const description = $json.description || \"\";\n\n// Extract using regex\nconst nameMatch = description.match(/Name:\\s*(.*)/i);\nconst contactMatch = description.match(/Contact:\\s*(.*)/i);\n\nconst customer_name = nameMatch ? nameMatch[1].trim() : null;\nconst customer_number = contactMatch ? contactMatch[1].trim() : null;\n\nreturn [\n  {\n    json: {\n      customer_name,\n      customer_number\n    }\n  }\n];"
      },
